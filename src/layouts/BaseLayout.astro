---
import '../styles/global.css';

const {
  title = 'tmhr94.github.io',
  description = 'Webエンジニアとしてリモートで働いているtmhr94の自己紹介ページとなります。',
} = Astro.props;

const pageTitle = title === 'tmhr94.github.io' ? title : `${title} | tmhr94.github.io`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-white text-zinc-900 antialiased">
    <div class="site-shell">
      <header class="sticky top-0 z-10 border-b border-zinc-200/80 bg-white/90 shadow-sm shadow-zinc-900/5 backdrop-blur-xl">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
          <a class="text-base font-semibold text-zinc-950 transition-colors hover:text-sky-700" href="/">
            tmhr94.github.io
          </a>
          <nav class="flex items-center gap-2 text-sm font-medium text-zinc-600">
            <a class="rounded-full px-3 py-2 transition-colors hover:bg-white hover:text-sky-700" href="/pages/about-me">More</a>
            <a class="rounded-full px-3 py-2 transition-colors hover:bg-white hover:text-sky-700" href="/pages/experience">Experience</a>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-6xl px-5 py-8 sm:py-12">
        <article class="content rounded bg-white px-5 py-7 shadow-xl shadow-zinc-900/10 ring-1 ring-zinc-200/70 sm:px-8 sm:py-10 lg:px-12">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

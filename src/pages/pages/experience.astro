---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('experiences');
const formatPeriod = (period, duration) => [period, duration].filter(Boolean).join(' - ');
const getStartYear = (period) => period.match(/\d{4}/)?.[0] ?? '';
const isOngoing = (period) => period.includes('現在継続');
const normalizeList = (value) => (Array.isArray(value) ? value : [String(value ?? '')]).filter(Boolean);
const normalizeSummary = (summary) =>
  Array.isArray(summary)
    ? summary
    : String(summary ?? '')
        .split('\n')
        .map((line) => line.trim().replace(/^[-*]\s*/, ''))
        .filter(Boolean);

const experiences = entries
  .map((entry) => {
    const summary = normalizeSummary(entry.data.summary);
    const affiliations = normalizeList(entry.data.affiliation);

    return {
      slug: entry.id.replace(/\.(md|ya?ml)$/, ''),
      ...entry.data,
      summary,
      affiliations,
      affiliationText: affiliations.join('\n'),
      startYear: getStartYear(entry.data.period),
      isOngoing: isOngoing(entry.data.period),
      formattedPeriod: formatPeriod(entry.data.period, entry.data.duration),
      searchableText: [
        entry.data.no,
        entry.data.title,
        formatPeriod(entry.data.period, entry.data.duration),
        entry.data.client,
        affiliations.join(' '),
        summary.join(' '),
        entry.data.techStack,
      ]
        .join(' ')
        .toLowerCase(),
    };
  })
  .sort((a, b) => b.no - a.no);

const affiliations = [...new Set(experiences.flatMap((experience) => experience.affiliations))].sort();
const tags = [
  ...new Set(experiences.flatMap((experience) => experience.tags ?? []).filter(Boolean)),
].sort((a, b) => a.localeCompare(b));
const years = [
  ...new Set(experiences.map((experience) => experience.startYear).filter(Boolean)),
].sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="職務経歴">
  <section class="space-y-8" data-experience-list>
    <div class="space-y-3"><h1>職務経歴</h1></div>

    <div class="grid gap-3 rounded border border-white bg-white/90 p-4 shadow-lg shadow-zinc-900/10 ring-1 ring-zinc-200/70 md:grid-cols-[1fr_10rem_14rem_14rem]">
      <label class="grid gap-1 text-sm font-medium text-zinc-700">
        キーワード
        <input
          class="min-h-11 rounded border border-zinc-300 bg-white px-3 text-base font-normal text-zinc-900 shadow-inner shadow-zinc-900/5 outline-none transition focus:border-sky-700 focus:ring-2 focus:ring-sky-700/20"
          type="search"
          placeholder="プロジェクト名、技術、クライアント"
          data-experience-search
        />
      </label>
      <label class="grid gap-1 text-sm font-medium text-zinc-700">
        年
        <select
          class="min-h-11 rounded border border-zinc-300 bg-white px-3 text-base font-normal text-zinc-900 shadow-inner shadow-zinc-900/5 outline-none transition focus:border-sky-700 focus:ring-2 focus:ring-sky-700/20"
          data-experience-year
        >
          <option value="">すべて</option>
          <option value="ongoing">現在継続</option>
          {years.map((year) => <option value={year}>{year}</option>)}
        </select>
      </label>
      <label class="grid gap-1 text-sm font-medium text-zinc-700">
        所属
        <select
          class="min-h-11 rounded border border-zinc-300 bg-white px-3 text-base font-normal text-zinc-900 shadow-inner shadow-zinc-900/5 outline-none transition focus:border-sky-700 focus:ring-2 focus:ring-sky-700/20"
          data-experience-affiliation
        >
          <option value="">すべて</option>
          {affiliations.map((affiliation) => <option value={affiliation}>{affiliation}</option>)}
        </select>
      </label>
      <label class="grid gap-1 text-sm font-medium text-zinc-700">
        技術
        <select
          class="min-h-11 rounded border border-zinc-300 bg-white px-3 text-base font-normal text-zinc-900 shadow-inner shadow-zinc-900/5 outline-none transition focus:border-sky-700 focus:ring-2 focus:ring-sky-700/20"
          data-experience-tag
        >
          <option value="">すべて</option>
          {tags.map((tag) => <option value={tag}>{tag}</option>)}
        </select>
      </label>
    </div>

    <div class="border-b border-zinc-200/80 pb-3 text-sm text-zinc-600">
      <p class="my-0"><span data-experience-count>{experiences.length}</span> 件</p>
    </div>

    <div class="grid gap-4" data-experience-items>
      {
        experiences.map((experience) => (
          <article
            class="rounded border border-white bg-white/95 p-5 shadow-lg shadow-zinc-900/10 ring-1 ring-zinc-200/70 transition hover:-translate-y-0.5 hover:shadow-xl hover:shadow-zinc-900/15"
            data-experience-item
            data-search={experience.searchableText}
            data-start-year={experience.startYear}
            data-ongoing={experience.isOngoing}
            data-affiliations={experience.affiliations.join('|')}
            data-tags={(experience.tags ?? []).join('|')}
          >
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="space-y-2">
                <p class="my-0 text-sm font-semibold text-sky-700">No.{experience.no}</p>
                <h2 class="my-0 border-0 pb-0 text-xl">
                  {
                    experience.hasDetail ? (
                      <a class="experience-title-link" href={`/pages/experience/${experience.slug}`}>
                        {experience.title}
                      </a>
                    ) : (
                      experience.title
                    )
                  }
                </h2>
              </div>
            </div>

            <dl class="mt-4 grid gap-3 rounded border border-zinc-200/80 bg-gradient-to-br from-zinc-50 to-sky-50/50 p-4 text-sm md:grid-cols-3">
              <div class="grid gap-1">
                <dt class="text-xs font-semibold uppercase tracking-wide text-sky-700">期間</dt>
                <dd class="text-zinc-950">{experience.formattedPeriod}</dd>
              </div>
              <div class="grid gap-1">
                <dt class="text-xs font-semibold uppercase tracking-wide text-sky-700">クライアント</dt>
                <dd class="whitespace-pre-line text-zinc-950">{experience.client}</dd>
              </div>
              <div class="grid gap-1">
                <dt class="text-xs font-semibold uppercase tracking-wide text-sky-700">所属</dt>
                <dd class="whitespace-pre-line text-zinc-950">{experience.affiliationText}</dd>
              </div>
            </dl>

            <div class="mt-4">
              <p class="my-0 text-sm font-semibold uppercase tracking-wide text-zinc-500">業務内容抜粋</p>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-zinc-700">
                {experience.summary.map((summary) => <li>{summary}</li>)}
              </ul>
            </div>

            <div class="mt-4 flex flex-wrap gap-2">
              {(experience.tags ?? []).slice(0, 12).map((tag) => (
                <span class="rounded-full border border-zinc-200 bg-white px-2.5 py-1 text-xs font-medium text-sky-800">{tag}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <p class="hidden rounded border border-zinc-200 bg-white p-5 text-zinc-600 shadow-sm" data-experience-empty>
      該当する職務経歴はありません。
    </p>
  </section>

  <script>
    const root = document.querySelector('[data-experience-list]');
    const search = root?.querySelector('[data-experience-search]');
    const year = root?.querySelector('[data-experience-year]');
    const affiliation = root?.querySelector('[data-experience-affiliation]');
    const tag = root?.querySelector('[data-experience-tag]');
    const items = [...(root?.querySelectorAll('[data-experience-item]') ?? [])];
    const count = root?.querySelector('[data-experience-count]');
    const empty = root?.querySelector('[data-experience-empty]');

    const filter = () => {
      const query = search?.value.trim().toLowerCase() ?? '';
      const selectedYear = year?.value ?? '';
      const selectedAffiliation = affiliation?.value ?? '';
      const selectedTag = tag?.value ?? '';
      let visibleCount = 0;

      items.forEach((item) => {
        const matchesQuery = !query || item.dataset.search?.includes(query);
        const matchesYear =
          !selectedYear ||
          (selectedYear === 'ongoing' ? item.dataset.ongoing === 'true' : item.dataset.startYear === selectedYear);
        const matchesAffiliation = !selectedAffiliation || item.dataset.affiliations?.split('|').includes(selectedAffiliation);
        const matchesTag = !selectedTag || item.dataset.tags?.split('|').includes(selectedTag);
        const visible = Boolean(matchesQuery && matchesYear && matchesAffiliation && matchesTag);

        item.classList.toggle('hidden', !visible);
        if (visible) visibleCount += 1;
      });

      if (count) count.textContent = String(visibleCount);
      empty?.classList.toggle('hidden', visibleCount !== 0);
    };

    search?.addEventListener('input', filter);
    year?.addEventListener('change', filter);
    affiliation?.addEventListener('change', filter);
    tag?.addEventListener('change', filter);
  </script>
</BaseLayout>

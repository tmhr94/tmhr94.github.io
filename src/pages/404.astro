---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <section class="mx-auto max-w-xl py-16 text-center">
    <h1 class="text-6xl font-semibold leading-none text-zinc-950">404</h1>
    <p class="mt-6 text-lg font-semibold text-zinc-900">Page not found :(</p>
    <p class="mt-2 text-zinc-600">The requested page could not be found.</p>
  </section>
</BaseLayout>
